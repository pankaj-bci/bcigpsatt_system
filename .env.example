# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY secret. Bypasses Row Level Security — never expose to the browser,
# never prefix with NEXT_PUBLIC_, never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Only needed if we end up using Vercel Cron instead of pg_cron (Section 11 of the migration plan)
CRON_SECRET=generate-a-random-string
